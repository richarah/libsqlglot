      {"name": "EVEN", "token_type": "EVEN"},
      {"name": "ALL", "token_type": "ALL"},
      {"name": "AUTO", "token_type": "AUTO"},
      {"name": "UNLOAD", "token_type": "UNLOAD"},
      {"name": "CREDENTIALS", "token_type": "CREDENTIALS"},
      {"name": "MANIFEST", "token_type": "MANIFEST"},
      {"name": "DELIMITER", "token_type": "DELIMITER_KW"},
      {"name": "FIXEDWIDTH", "token_type": "FIXEDWIDTH"},
      {"name": "ACCEPTINVCHARS", "token_type": "ACCEPTINVCHARS"},
      {"name": "ACCEPTANYDATE", "token_type": "ACCEPTANYDATE"},
      {"name": "BLANKSASNULL", "token_type": "BLANKSASNULL"},
      {"name": "DATEFORMAT", "token_type": "DATEFORMAT"},
      {"name": "EMPTYASNULL", "token_type": "EMPTYASNULL"},
      {"name": "ENCODING", "token_type": "ENCODING"},
      {"name": "ESCAPE", "token_type": "ESCAPE"},
      {"name": "EXPLICIT", "token_type": "EXPLICIT"},
      {"name": "FILLRECORD", "token_type": "FILLRECORD"},
      {"name": "IGNOREBLANKLINES", "token_type": "IGNOREBLANKLINES"},
      {"name": "IGNOREHEADER", "token_type": "IGNOREHEADER"},
      {"name": "NULL_KW", "token_type": "NULL_KW"},
      {"name": "READRATIO", "token_type": "READRATIO"},
      {"name": "REGION", "token_type": "REGION"},
      {"name": "REMOVEQUOTES", "token_type": "REMOVEQUOTES"},
      {"name": "ROUNDEC", "token_type": "ROUNDEC"},
      {"name": "TIMEFORMAT", "token_type": "TIMEFORMAT"},
      {"name": "TRIMBLANKS", "token_type": "TRIMBLANKS"},
